{
  "manifest_version": 3,
  "name": "Karakeep Dashboard Companion",
  "version": "1.0.0",
  "description": "Bridges Chrome tabs/windows APIs to the Karakeep Dashboard web app",
  "permissions": ["tabs", "storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Save to Karakeep",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:5174/*",
      "http://localhost:4174/*",
      "http://127.0.0.1:5174/*",
      "http://127.0.0.1:4174/*",
      "http://karakeep-dashboard.beaver-hen.ts.net/*",
      "http://100.114.3.92/*"
    ]
  }
}
